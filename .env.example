# Folder Syncer (Go) — environment configuration
# Copy this file to .env and adjust the values.

SYNC_WATCH_DIR=data
SYNC_REDIS_HOST=localhost
SYNC_REDIS_PORT=6379
SYNC_REDIS_PASSWORD=
SYNC_REDIS_DB=0
SYNC_REDIS_KEY_PREFIX=file_cache:
SYNC_PID_FILE=/tmp/folder_syncer.pid
SYNC_LOG_FILE=/tmp/folder_syncer.log
